# Copy to .env and fill in real values. Never commit .env.

# ── Required for full LLM quality ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY_FALLBACK=your_secondary_gemini_key_here

# ── Optional live news sources ───────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
BING_SEARCH_API_KEY=your_bing_search_v7_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ── Pathway VectorStore (Docker / Linux) ─────────────────────────────────────
PATHWAY_HOST=127.0.0.1
PATHWAY_PORT=8765
PATHWAY_SOURCE_GLOB=data/pathway_sources/*.json
PATHWAY_REFRESH_INTERVAL_MS=30000
PATHWAY_RSS_REFRESH_INTERVAL_MS=60000
NEWS_SYNC_QUERY=US China trade talks

# ── Agent settings ───────────────────────────────────────────────────────────
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
CRAG_RELEVANCE_THRESHOLD=0.72
M1_CONFIDENCE_THRESHOLD=0.80
RETRIEVAL_TOP_K=15

# ── Resilience demo (comma-separated: pathway,bing,scraper) ─────────────────
SIMULATE_RETRIEVAL_FAILURES=

# ── Local dev helpers ────────────────────────────────────────────────────────
SEED_DEMO_DATA=true
LOG_LEVEL=INFO
