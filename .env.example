# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Safe template. Copy to .env and fill in real values.
# NEVER commit .env or .env.local — they contain real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── News Sources ──────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_ai_key_here
BING_SEARCH_API_KEY=your_bing_search_v7_key_here

# ── Pathway VectorStore ───────────────────────────────────────────────────────
PATHWAY_HOST=0.0.0.0
PATHWAY_PORT=8765
PATHWAY_REFRESH_INTERVAL_MS=30000
PATHWAY_RSS_REFRESH_INTERVAL_MS=60000

# ── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
M1_LLM_MODEL=gpt-4o-mini
M5_LLM_MODEL=gpt-4o
M1_CONFIDENCE_THRESHOLD=0.80
GROQ_API_KEY=your_groqkey_here

# ── LLM Fallbacks ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OLLAMA_HOST=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2:3b

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── CRAG ──────────────────────────────────────────────────────────────────────
CRAG_RELEVANCE_THRESHOLD=0.72
CRAG_TOP_K=15
